rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives & Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Pillar 2: Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt']) &&
             data.keys().size() >= 2 &&
             data.email is string && data.email.size() <= 256 &&
             data.createdAt is timestamp;
    }

    function isValidHistoryItem(data) {
      return data.keys().hasAll(['userId', 'image', 'result', 'timestamp']) &&
             data.keys().size() >= 4 &&
             data.userId == request.auth.uid &&
             data.image is string && data.image.size() <= 2000000 && // 2MB limit for base64
             data.result is string && data.result.size() <= 50000 &&
             data.timestamp == request.time;
    }

    // User profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL'])
      );
      
      // History subcollection
      match /history/{itemId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(itemId) && isValidHistoryItem(incoming());
        allow delete: if isOwner(userId);
      }
    }
  }
}
